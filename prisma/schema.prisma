// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountProvider {
  GITHUB
  TELEGRAM
  DISCORD
}

enum ReminderStatus {
  PENDING
  SENT
  CANCELED
  FAILED
}

model User {
  id                String             @id @default(cuid())
  clerkUserId       String             @unique
  aiModel           String             @default("gemini-2.5-flash-lite")
  linkedAccounts    LinkedAccount[]
  pendingLinks      PendingLink[]
  reminders         Reminder[]
  trackedRepos      TrackedRepo[]
  dailySummaries    DailySummary[]
  notificationRules NotificationRule[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model LinkedAccount {
  id             String          @id @default(cuid())
  userId         String
  provider       AccountProvider
  providerUserId String
  username       String?
  accessToken    String?
  refreshToken   String?
  chatId         String?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId, provider])
}

model PendingLink {
  id         String          @id @default(cuid())
  token      String          @unique
  provider   AccountProvider
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  metadata   Json?
  createdAt  DateTime        @default(now())
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider])
  @@index([provider, expiresAt])
}

model Reminder {
  id          String         @id @default(cuid())
  userId      String
  issueNumber Int
  repository  String
  remindAt    DateTime
  status      ReminderStatus @default(PENDING)
  note        String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  archived    Boolean        @default(false)

  @@index([userId, status])
  @@index([repository, issueNumber])
}

model TrackedRepo {
  id                String             @id @default(cuid())
  userId            String
  fullName          String
  isDefault         Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationRules NotificationRule[]

  @@unique([userId, fullName])
  @@index([userId])
}

model NotificationRule {
  id               String          @id @default(cuid())
  userId           String
  repoId           String
  provider         AccountProvider
  events           String[]
  channelOverrides Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo TrackedRepo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([repoId, provider])
  @@index([userId, provider])
}

model DailySummary {
  id        String   @id @default(cuid())
  userId    String
  date      String // Format: YYYY-MM-DD
  summary   Json // Storing GithubDailySummaryResponse
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}
